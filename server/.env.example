# Railway PostgreSQL (or Supabase) connection string
DATABASE_URL=postgresql://postgres:password@hostname:5432/railway

# Required in production
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# Vercel frontend URL (no trailing slash) — used for CORS
CLIENT_URL=https://your-app.vercel.app

# Public API URL for server-initiated requests (optional; defaults to 127.0.0.1:PORT)
# API_URL=https://your-api.up.railway.app

# SSL for DATABASE_URL (Railway internal URLs often need DATABASE_SSL=false)
# DATABASE_SSL=true

# Email: Resend (preferred) or SMTP
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=HRDC Trainer <notifications@yourdomain.com>
ADMIN_EMAIL=admin@example.com

# SMTP fallback (if RESEND_API_KEY is unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Optional: persistent upload path (Railway volume mount path)
# UPLOAD_DIR=/data/uploads

# Extra CORS origins (comma-separated)
# CORS_ORIGINS=https://preview.vercel.app

# Alibaba Qwen (DashScope) — training provider scraper + certificate verification
DASHSCOPE_API_KEY=sk-6c4f6e7648844b5982e1321c85e44cb7
# Optional: use cn if your key is from China (Beijing) Model Studio; default is intl (Singapore)
# DASHSCOPE_REGION=cn
# Optional overrides (defaults are derived from region):
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
# DASHSCOPE_API_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_COMPAT_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus-latest

# HRDC eTRiS training provider listing (optional override)
# TRAINING_PROVIDERS_LISTING_URL=https://etris.hrdcorp.gov.my/DigiGov/digigovportal.htm?actionFlag=SC_getSearchCompoPage&...

# Scrape HRDC providers to CSV (not the database):
#   npm run db:scrape-providers
#   → data/training-providers.csv (columns: provider, email, telephone, address)
# Load CSV into PostgreSQL for the admin UI:
#   npm run db:import-providers-csv
# TRAINING_PROVIDERS_CSV_PATH=
# Optional scraper limits (0 = no limit). Full HRDC catalog is ~7,400 providers.
# SCRAPE_MAX_PAGES=5
# SCRAPE_MAX_PROVIDERS=100
# Fast re-scrape (~10–20 min): listing email/phone only, skip per-provider detail pages
# SCRAPE_SKIP_DETAIL=1
# SCRAPE_SKIP_WEBSITE_ENRICH=1
# If data/training-providers.csv exists, scrape appends missing rows only (default).
# SCRAPE_REPLACE=1
# Fix duplicates without re-scraping: npm run db:dedupe-providers-csv

# Seed script (npm run db:seed) — run locally or via Railway one-off
ADMIN_PASSWORD=change-me
# Legacy alias (still supported)
# CLIENT_ORIGIN=http://localhost:5173
